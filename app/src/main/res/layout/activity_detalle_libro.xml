<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cream_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:gravity="center_horizontal">

        <ImageView
            android:id="@+id/ivDetallePortada"
            android:layout_width="180dp"
            android:layout_height="260dp"
            android:layout_marginTop="16dp"
            android:scaleType="centerCrop"
            android:background="#DDDDDD"
            android:elevation="8dp"/>

        <TextView
            android:id="@+id/tvDetalleTitulo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center"
            android:text="Título"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@color/black"/>

        <TextView
            android:id="@+id/tvDetalleAutor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center"
            android:text="Autor"
            android:textSize="18sp"
            android:textColor="#555555"/>

        <TextView
            android:id="@+id/tvDetalleEstado"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:paddingHorizontal="16dp"
            android:paddingVertical="6dp"
            android:background="#E0E0E0"
            android:text="ESTADO: PENDIENTE"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/black"/>

        <TextView
            android:id="@+id/tvDetalleSinopsis"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Sinopsis..."
            android:textSize="16sp"
            android:lineSpacingExtra="4dp"
            android:textColor="@color/black"
            android:justificationMode="inter_word"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#CCCCCC"
            android:layout_marginVertical="24dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Cambiar estado del libro:"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:layout_marginBottom="12dp"/>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <Button
                android:id="@+id/btnPendiente"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="2dp"
                app:layout_constraintHorizontal_chainStyle="spread_inside"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@id/btnLeyendo"
                app:layout_constraintTop_toTopOf="parent"
                android:backgroundTint="#757575"
                android:textSize="10sp"
                android:text="Pendiente"/>

            <Button
                android:id="@+id/btnLeyendo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="2dp"
                app:layout_constraintStart_toEndOf="@id/btnPendiente"
                app:layout_constraintEnd_toStartOf="@id/btnLeido"
                app:layout_constraintTop_toTopOf="parent"
                android:backgroundTint="#FF9800"
                android:textSize="10sp"
                android:text="Leyendo"/>

            <Button
                android:id="@+id/btnLeido"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="2dp"
                app:layout_constraintStart_toEndOf="@id/btnLeyendo"
                app:layout_constraintEnd_toStartOf="@id/btnQuieroLeer"
                app:layout_constraintTop_toTopOf="parent"
                android:backgroundTint="#4CAF50"
                android:textSize="10sp"
                android:text="Leído"/>

            <Button
                android:id="@+id/btnQuieroLeer"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="2dp"
                app:layout_constraintStart_toEndOf="@id/btnLeido"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                android:backgroundTint="#9C27B0"
                android:textSize="10sp"
                android:text="Quiero leer"/>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#CCCCCC"
            android:layout_marginVertical="20dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Mi progreso de lectura:"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <EditText
                android:id="@+id/etPaginaActual"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Página actual"
                android:inputType="number"
                android:textSize="14sp"/>

            <Button
                android:id="@+id/btnGuardarProgreso"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:backgroundTint="@color/black"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:text="Guardar"/>

        </LinearLayout>

        <ProgressBar
            android:id="@+id/pbProgreso"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="12dp"
            android:layout_marginTop="8dp"
            android:max="100"
            android:progress="0"
            android:progressTint="#4CAF50"/>

        <TextView
            android:id="@+id/tvPorcentaje"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center"
            android:textSize="13sp"
            android:textColor="#555555"
            android:text="0%"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#CCCCCC"
            android:layout_marginVertical="20dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <Button
                android:id="@+id/btnEliminar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:backgroundTint="#D32F2F"
                android:textColor="@color/white"
                android:text="Eliminar"/>

            <Button
                android:id="@+id/btnRecomendar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:backgroundTint="#1976D2"
                android:textColor="@color/white"
                android:text="Recomendar"/>

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#CCCCCC"
            android:layout_marginVertical="20dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Reseñas"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="@color/black"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tvMediaResenas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:textColor="#555555"
            android:layout_marginBottom="12dp"
            android:text="Sin valoraciones aún"/>

        <RatingBar
            android:id="@+id/rbNuevaResena"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:numStars="5"
            android:stepSize="0.5"
            android:rating="0"/>

        <EditText
            android:id="@+id/etTextoResena"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="Escribe tu reseña..."
            android:inputType="textMultiLine"
            android:minLines="3"
            android:maxLines="6"
            android:gravity="top"
            android:textSize="14sp"/>

        <Button
            android:id="@+id/btnPublicarResena"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:backgroundTint="@color/black"
            android:textColor="@color/white"
            android:text="Publicar reseña"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvResenas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:nestedScrollingEnabled="false"
            android:layout_marginBottom="32dp"/>

    </LinearLayout>
</ScrollView>